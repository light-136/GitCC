<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        浅色主题 — 设计思路：
        以 #F5F5F5 为页面底色，卡片用纯白 #FFFFFF 营造浮起层次感，
        输入框用 #F0F2F5 柔灰与卡片区分，边框用 #E0E0E0 淡灰不刺眼。
        强调色选用较深饱和度，保证在白底上的对比度 ≥ 4.5:1（WCAG AA）。
        文字主色 #1B1B1F 近黑不纯黑，减少视觉疲劳。
    -->

    <!-- 基础底色 -->
    <SolidColorBrush x:Key="BgDarkBrush"      Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BgMidBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgLightBrush"     Color="#F0F2F5"/>

    <!-- 强调色 -->
    <SolidColorBrush x:Key="AccentBrush"       Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentGreenBrush"  Color="#16A34A"/>
    <SolidColorBrush x:Key="AccentRedBrush"    Color="#DC2626"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#D97706"/>

    <!-- 文字 -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#1B1B1F"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>

    <!-- 边框 -->
    <SolidColorBrush x:Key="BorderBrush"  Color="#E0E0E0"/>

    <!-- DataGrid 列头 — 浅色主题下用淡蓝灰底 + 深蓝文字 -->
    <SolidColorBrush x:Key="DataGridHeaderBgBrush" Color="#EEF2FF"/>
    <SolidColorBrush x:Key="DataGridHeaderFgBrush" Color="#2563EB"/>

    <!-- DataGrid 选中行高亮 -->
    <SolidColorBrush x:Key="DataGridSelectedRowBrush" Color="#BFDBFE"/>

    <!-- DataGrid 网格线 -->
    <SolidColorBrush x:Key="DataGridGridLineBrush" Color="#E5E7EB"/>

</ResourceDictionary>
