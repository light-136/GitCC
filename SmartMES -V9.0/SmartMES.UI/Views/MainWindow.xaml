<Window x:Class="SmartMES.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartMES.UI.ViewModels"
        xmlns:views="clr-namespace:SmartMES.UI.Views"
        xmlns:mes="clr-namespace:SmartMES.UI.Modules.MesCommModule"
        xmlns:file="clr-namespace:SmartMES.UI.Modules.FileModule"
        xmlns:db="clr-namespace:SmartMES.UI.Modules.DatabaseModule"
        xmlns:motion="clr-namespace:SmartMES.UI.Modules.MotionModule"
        xmlns:native="clr-namespace:SmartMES.UI.Modules.NativeModule"
        xmlns:m10="clr-namespace:SmartMES.UI.Modules.Motion10AxisModule"
        xmlns:vis="clr-namespace:SmartMES.UI.Modules.VisionModule"
        xmlns:vism="clr-namespace:SmartMES.UI.Modules.VisionMotionModule"
        xmlns:ind="clr-namespace:SmartMES.UI.Modules.IndustrialModule"
        xmlns:rpt="clr-namespace:SmartMES.UI.Modules.ReportModule"
        xmlns:secsgem="clr-namespace:SmartMES.UI.Modules.SecsGemModule"
        xmlns:visv2="clr-namespace:SmartMES.UI.Modules.VisionV2Module"
        Title="{Binding CurrentPageTitle, StringFormat='SmartMES - {0}'}"
        Width="1440" Height="860" MinWidth="1100" MinHeight="660"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeviceViewModel}"><views:DeviceView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AlarmViewModel}"><views:AlarmView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewModel}"><views:LogView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserViewModel}"><views:UserView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CommunicationViewModel}"><views:CommunicationView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AutomationViewModel}"><views:AutomationView/></DataTemplate>
        <DataTemplate DataType="{x:Type mes:MesCommViewModel}"><mes:MesCommView/></DataTemplate>
        <DataTemplate DataType="{x:Type file:FileViewModel}"><file:FileView/></DataTemplate>
        <DataTemplate DataType="{x:Type db:DatabaseViewModel}"><db:DatabaseView/></DataTemplate>
        <DataTemplate DataType="{x:Type motion:MotionViewModel}"><motion:MotionView/></DataTemplate>
        <DataTemplate DataType="{x:Type native:NativeViewModel}"><native:NativeView/></DataTemplate>
        <DataTemplate DataType="{x:Type m10:Motion10AxisViewModel}"><m10:Motion10AxisView/></DataTemplate>
        <DataTemplate DataType="{x:Type vis:VisionViewModel}"><vis:VisionView/></DataTemplate>
        <DataTemplate DataType="{x:Type vism:VisionMotionViewModel}"><vism:VisionMotionView/></DataTemplate>
        <DataTemplate DataType="{x:Type ind:IndustrialViewModel}"><ind:IndustrialView/></DataTemplate>
        <DataTemplate DataType="{x:Type rpt:ReportViewModel}"><rpt:ReportView/></DataTemplate>
        <DataTemplate DataType="{x:Type secsgem:SecsGemViewModel}"><secsgem:SecsGemView/></DataTemplate>
        <DataTemplate DataType="{x:Type visv2:VisionV2ViewModel}"><visv2:VisionV2View/></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgMidBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock Text="SmartMES" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text=" / " Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="4,0"/>
                    <TextBlock Text="{Binding CurrentPageTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUser, StringFormat='👤 {0}'}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding CurrentUserRole, StringFormat='[{0}]'}" Foreground="{StaticResource AccentBrush}" FontSize="12" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding SystemTime}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgMidBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8">
                        <TextBlock Text="监控" Style="{StaticResource SecondaryText}" Margin="20,4,0,4" FontSize="10" FontWeight="Bold"/>
        <Button Content="📊  实时仪表盘" Style="{StaticResource NavButton}" Command="{Binding NavDashboardCommand}"
                                Visibility="{Binding CanAccessDashboard, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🔌  设备管理" Style="{StaticResource NavButton}" Command="{Binding NavDeviceCommand}"
                                Visibility="{Binding CanAccessDevice, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📡  通信监控" Style="{StaticResource NavButton}" Command="{Binding NavCommunicationCommand}"
                                Visibility="{Binding CanAccessCommunication, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🔔  报警管理" Style="{StaticResource NavButton}" Command="{Binding NavAlarmCommand}"
                                Visibility="{Binding CanAccessAlarm, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📋  系统日志" Style="{StaticResource NavButton}" Command="{Binding NavLogCommand}"
                                Visibility="{Binding CanAccessLog, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="⚡  自动化流程" Style="{StaticResource NavButton}" Command="{Binding NavAutomationCommand}"
                                Visibility="{Binding CanAccessAutomation, Converter={StaticResource BoolToVisConverter}}"/>

                        <Separator Margin="16,8" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="扩展模块" Style="{StaticResource SecondaryText}" Margin="20,0,0,4" FontSize="10" FontWeight="Bold"/>
                        <Button Content="🏭  MES通信" Style="{StaticResource NavButton}" Command="{Binding NavMesCommCommand}"
                                Visibility="{Binding CanAccessMesComm, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📁  文件处理" Style="{StaticResource NavButton}" Command="{Binding NavFileCommand}"
                                Visibility="{Binding CanAccessFile, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🗄  数据库" Style="{StaticResource NavButton}" Command="{Binding NavDatabaseCommand}"
                                Visibility="{Binding CanAccessDatabase, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🎯  运动控制中心" Style="{StaticResource NavButton}" Command="{Binding NavMotionCommand}"
                                Visibility="{Binding CanAccessMotion, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="⚙  C++ Native" Style="{StaticResource NavButton}" Command="{Binding NavNativeCommand}"
                                Visibility="{Binding CanAccessNative, Converter={StaticResource BoolToVisConverter}}"/>

                        <Border Margin="12,8,12,0" Padding="8" Background="#1F2638" BorderBrush="#2E3A55" BorderThickness="1" CornerRadius="6"
                                Visibility="{Binding HasSampleAccess, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel>
                                <TextBlock Text="MOTION CENTER" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="11" Margin="0,0,0,6"/>
                                <Button Content="🔢  10轴运动样例" Style="{StaticResource NavButton}" Command="{Binding NavMotion10Command}"
                                        Visibility="{Binding CanAccessMotion10, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="👁  视觉检测样例" Style="{StaticResource NavButton}" Command="{Binding NavVisionCommand}"
                                        Visibility="{Binding CanAccessVision, Converter={StaticResource BoolToVisConverter}}"/>
                                <Button Content="🤖  视觉+运动协同" Style="{StaticResource NavButton}" Command="{Binding NavVisionMotionCommand}"
                                        Visibility="{Binding CanAccessVisionMotion, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>
                        </Border>

                        <Separator Margin="16,8" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="半导体 &amp; 算法" Style="{StaticResource SecondaryText}" Margin="20,0,0,4" FontSize="10" FontWeight="Bold"/>
                        <Button Content="🔬  SECS/GEM 通信" Style="{StaticResource NavButton}" Command="{Binding NavSecsGemCommand}"
                                Visibility="{Binding CanAccessSecsGem, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="🧠  视觉算法V2" Style="{StaticResource NavButton}" Command="{Binding NavVisionV2Command}"
                                Visibility="{Binding CanAccessVisionV2, Converter={StaticResource BoolToVisConverter}}"/>

                        <Separator Margin="16,8" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="工业级能力" Style="{StaticResource SecondaryText}" Margin="20,0,0,4" FontSize="10" FontWeight="Bold"/>
                        <Button Content="🏗  工业系统总览" Style="{StaticResource NavButton}" Command="{Binding NavIndustrialCommand}"
                                Visibility="{Binding CanAccessIndustrial, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="📈  报表统计" Style="{StaticResource NavButton}" Command="{Binding NavReportCommand}"
                                Visibility="{Binding CanAccessReport, Converter={StaticResource BoolToVisConverter}}"/>

                        <Separator Margin="16,8" Background="{StaticResource BorderBrush}"/>
                        <TextBlock Text="系统" Style="{StaticResource SecondaryText}" Margin="20,0,0,4" FontSize="10" FontWeight="Bold"/>
                        <Button Content="⚙  参数配置" Style="{StaticResource NavButton}" Command="{Binding NavSettingsCommand}"
                                Visibility="{Binding CanAccessSettings, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="👤  用户管理" Style="{StaticResource NavButton}" Command="{Binding NavUserCommand}"
                                Visibility="{Binding CanAccessUser, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
        </Grid>
    </Grid>
</Window>
