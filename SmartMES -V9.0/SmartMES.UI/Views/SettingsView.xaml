<UserControl x:Class="SmartMES.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 报警阈值 -->
            <Border Grid.Row="0" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="⚠ 报警阈值设置"
                               Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="温度上限 (°C):"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding TempThreshold, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="压力上限 (MPa):"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="4" Grid.Column="1"
                               Text="{Binding PressureThreshold, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="速度上限 (rpm):"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1"
                               Text="{Binding SpeedThreshold, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <!-- 通信参数 -->
            <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="📡 通信参数"
                               Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="TCP服务器IP:"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding TcpServerIp, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="TCP端口:"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="串口号:"
                               VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding SerialPort, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Button Content="💾 保存配置" Style="{StaticResource SuccessButton}" Command="{Binding SaveCommand}"/>
                <Button Content="🔄 重新加载" Style="{StaticResource PrimaryButton}" Command="{Binding ReloadCommand}"/>
                <TextBlock Text="{Binding SaveStatus}" VerticalAlignment="Center"
                           Foreground="{StaticResource AccentGreenBrush}" FontSize="13"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
