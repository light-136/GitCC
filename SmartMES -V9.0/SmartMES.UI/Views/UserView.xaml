<UserControl x:Class="SmartMES.UI.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <!-- 浅色主题颜色 — 全部定义在控件内部，复制即用，无外部依赖 -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- 底色 -->
        <SolidColorBrush x:Key="LightBgPage"       Color="#F5F5F5"/>
        <SolidColorBrush x:Key="LightBgCard"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightBgInput"      Color="#F0F2F5"/>

        <!-- 文字 -->
        <SolidColorBrush x:Key="LightTextPrimary"   Color="#1B1B1F"/>
        <SolidColorBrush x:Key="LightTextSecondary" Color="#6B7280"/>

        <!-- 强调色 -->
        <SolidColorBrush x:Key="LightAccent"        Color="#2563EB"/>
        <SolidColorBrush x:Key="LightAccentGreen"   Color="#16A34A"/>
        <SolidColorBrush x:Key="LightAccentRed"     Color="#DC2626"/>
        <SolidColorBrush x:Key="LightAccentOrange"  Color="#D97706"/>

        <!-- 边框 -->
        <SolidColorBrush x:Key="LightBorder"        Color="#E0E0E0"/>

        <!-- DataGrid 专用 -->
        <SolidColorBrush x:Key="LightDgHeaderBg"    Color="#EEF2FF"/>
        <SolidColorBrush x:Key="LightDgHeaderFg"    Color="#2563EB"/>
        <SolidColorBrush x:Key="LightDgSelectedRow" Color="#BFDBFE"/>
        <SolidColorBrush x:Key="LightDgGridLine"    Color="#E5E7EB"/>

        <!-- 按钮样式 — 自包含，不依赖外部 Styles.xaml -->
        <Style x:Key="LightBtnBase" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightSuccessBtn" TargetType="Button" BasedOn="{StaticResource LightBtnBase}">
            <Setter Property="Background" Value="{StaticResource LightAccentGreen}"/>
        </Style>
        <Style x:Key="LightDangerBtn" TargetType="Button" BasedOn="{StaticResource LightBtnBase}">
            <Setter Property="Background" Value="{StaticResource LightAccentRed}"/>
        </Style>
        <Style x:Key="LightOrangeBtn" TargetType="Button" BasedOn="{StaticResource LightBtnBase}">
            <Setter Property="Background" Value="{StaticResource LightAccentOrange}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左列：登录面板 ========== -->
        <StackPanel Grid.Column="0">

            <!-- 当前登录 -->
            <Border Margin="0,0,0,12" CornerRadius="6" Padding="16"
                    Background="{StaticResource LightBgCard}"
                    BorderBrush="{StaticResource LightBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="👤 当前登录" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource LightTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CurrentUser.DisplayName, FallbackValue='未登录'}"
                               FontSize="20" FontWeight="Bold" Foreground="{StaticResource LightAccent}"/>
                    <TextBlock Text="{Binding RoleText, StringFormat='角色: {0}'}"
                               FontSize="12" Foreground="{StaticResource LightTextSecondary}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding CurrentUser.LastLoginAt, StringFormat='登录时间: {0:HH:mm:ss}', FallbackValue=''}"
                               FontSize="12" Foreground="{StaticResource LightTextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 用户登录 -->
            <Border Margin="0,0,0,12" CornerRadius="6" Padding="16"
                    Background="{StaticResource LightBgCard}"
                    BorderBrush="{StaticResource LightBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="🔐 用户登录" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource LightTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="用户名" FontSize="12"
                               Foreground="{StaticResource LightTextSecondary}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"
                             Background="{StaticResource LightBgInput}" Foreground="{StaticResource LightTextPrimary}"
                             BorderBrush="{StaticResource LightBorder}" Padding="8,6"/>
                    <TextBlock Text="密码" FontSize="12"
                               Foreground="{StaticResource LightTextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PwdBox" Margin="0,0,0,10"
                                 PasswordChanged="PwdBox_PasswordChanged"
                                 Background="{StaticResource LightBgInput}" Foreground="{StaticResource LightTextPrimary}"
                                 BorderBrush="{StaticResource LightBorder}" Padding="8,6"/>
                    <TextBlock Text="{Binding LoginMessage}" Foreground="{StaticResource LightAccentOrange}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🔓 登录" Style="{StaticResource LightSuccessBtn}"
                                Command="{Binding LoginCommand}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="🚪 登出" Style="{StaticResource LightDangerBtn}"
                                Command="{Binding LogoutCommand}" Width="90"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 内置账号 -->
            <Border CornerRadius="6" Padding="16"
                    Background="{StaticResource LightBgCard}"
                    BorderBrush="{StaticResource LightBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📋 内置账号" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource LightTextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="admin / admin123 → 管理员（全权限）" FontSize="12"
                               Foreground="{StaticResource LightTextSecondary}" Margin="0,2,0,4"/>
                    <TextBlock Text="operator / op123 → 操作员" FontSize="12"
                               Foreground="{StaticResource LightTextSecondary}" Margin="0,2,0,4"/>
                    <TextBlock Text="viewer / view123 → 只读观察者" FontSize="12"
                               Foreground="{StaticResource LightTextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ========== 中列：用户列表 ========== -->
        <Border Grid.Column="2" CornerRadius="6" Padding="0"
                Background="{StaticResource LightBgCard}"
                BorderBrush="{StaticResource LightBorder}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="👥 用户列表" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource LightTextPrimary}" Margin="16,12,16,8"/>

                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="12,0,12,8"
                           IsEnabled="{Binding IsAdmin}">
                    <Button Content="➕ 新增" Style="{StaticResource LightSuccessBtn}" Command="{Binding NewUserCommand}" Margin="0,0,6,0"/>
                    <Button Content="🗑 删除" Style="{StaticResource LightDangerBtn}"  Command="{Binding DeleteUserCommand}"/>
                    <TextBlock Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"
                               Text="⚠ 仅管理员可管理用户" Foreground="{StaticResource LightAccentOrange}"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </WrapPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                          IsReadOnly="True" AutoGenerateColumns="False"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" SelectionMode="Single"
                          Background="{StaticResource LightBgCard}"
                          Foreground="{StaticResource LightTextPrimary}"
                          BorderBrush="{StaticResource LightBorder}" BorderThickness="0,1,0,0"
                          RowBackground="{StaticResource LightBgCard}"
                          AlternatingRowBackground="{StaticResource LightBgInput}"
                          HorizontalGridLinesBrush="{StaticResource LightDgGridLine}"
                          VerticalGridLinesBrush="{StaticResource LightDgGridLine}">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"      Value="{StaticResource LightDgHeaderBg}"/>
                            <Setter Property="Foreground"      Value="{StaticResource LightDgHeaderFg}"/>
                            <Setter Property="FontWeight"      Value="Bold"/>
                            <Setter Property="Padding"         Value="10,8"/>
                            <Setter Property="BorderBrush"     Value="{StaticResource LightBorder}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{StaticResource LightTextPrimary}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource LightDgSelectedRow}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource LightDgSelectedRow}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"          Value="8,6"/>
                            <Setter Property="BorderBrush"      Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource LightDgSelectedRow}"/>
                                    <Setter Property="Foreground" Value="{StaticResource LightTextPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="用户名"   Binding="{Binding Username}"    Width="100"/>
                        <DataGridTextColumn Header="显示名"   Binding="{Binding DisplayName}" Width="90"/>
                        <DataGridTextColumn Header="角色"     Binding="{Binding Role}"        Width="80"/>
                        <DataGridTextColumn Header="启用"     Binding="{Binding IsActive}"    Width="55"/>
                        <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAt, StringFormat=HH:mm:ss}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ========== 右列：权限编辑面板 ========== -->
        <Border Grid.Column="4" CornerRadius="6" Padding="16"
                IsEnabled="{Binding IsAdmin}"
                Background="{StaticResource LightBgCard}"
                BorderBrush="{StaticResource LightBorder}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="🔑 权限编辑" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource LightTextPrimary}" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding IsEditing}">
                        <TextBlock Text="基本信息" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"
                                   Foreground="{StaticResource LightTextSecondary}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="用户名" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource LightTextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.Username, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource LightBgInput}" Foreground="{StaticResource LightTextPrimary}"
                                     BorderBrush="{StaticResource LightBorder}" Padding="8,5"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="显示名" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource LightTextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource LightBgInput}" Foreground="{StaticResource LightTextPrimary}"
                                     BorderBrush="{StaticResource LightBorder}" Padding="8,5"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="密码" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource LightTextSecondary}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.Password, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource LightBgInput}" Foreground="{StaticResource LightTextPrimary}"
                                     BorderBrush="{StaticResource LightBorder}" Padding="8,5"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource LightBorder}" Margin="0,0,0,10"/>

                        <TextBlock Text="页面权限" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"
                                   Foreground="{StaticResource LightTextSecondary}"/>
                        <CheckBox Content="仪表盘"       IsChecked="{Binding EditUser.Permissions.Dashboard}"      Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="设备管理"     IsChecked="{Binding EditUser.Permissions.Device}"          Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="通信监控"     IsChecked="{Binding EditUser.Permissions.Communication}"    Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="报警管理"     IsChecked="{Binding EditUser.Permissions.Alarm}"            Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="系统日志"     IsChecked="{Binding EditUser.Permissions.Log}"              Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="自动化流程"   IsChecked="{Binding EditUser.Permissions.Automation}"       Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="MES通信"      IsChecked="{Binding EditUser.Permissions.MesComm}"         Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="文件处理"     IsChecked="{Binding EditUser.Permissions.FileProcess}"     Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="数据库"       IsChecked="{Binding EditUser.Permissions.Database}"         Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="运动控制"     IsChecked="{Binding EditUser.Permissions.Motion}"           Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="C++ Native"   IsChecked="{Binding EditUser.Permissions.Native}"          Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="10轴运动样例" IsChecked="{Binding EditUser.Permissions.Motion10Axis}"    Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="视觉样例"     IsChecked="{Binding EditUser.Permissions.Vision}"           Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="视觉+运动协同" IsChecked="{Binding EditUser.Permissions.VisionMotion}"   Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>
                        <CheckBox Content="工业系统总览" IsChecked="{Binding EditUser.Permissions.Industrial}"       Foreground="{StaticResource LightTextPrimary}" Margin="0,3"/>

                        <Border Height="1" Background="{StaticResource LightBorder}" Margin="0,6,0,6"/>

                        <CheckBox Content="参数配置"     IsChecked="{Binding EditUser.Permissions.Settings}"        Foreground="{StaticResource LightAccentOrange}" Margin="0,3"/>
                        <CheckBox Content="用户管理"     IsChecked="{Binding EditUser.Permissions.UserManage}"      Foreground="{StaticResource LightAccentOrange}" Margin="0,3"/>
                    </StackPanel>
                </ScrollViewer>

                <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="✅ 保存" Style="{StaticResource LightSuccessBtn}" Command="{Binding SaveUserCommand}"   Margin="0,0,8,0"/>
                    <Button Content="✏ 编辑" Style="{StaticResource LightOrangeBtn}"  Command="{Binding NewUserCommand}"   Margin="0,0,8,0"/>
                    <Button Content="❌ 取消" Style="{StaticResource LightDangerBtn}"  Command="{Binding CancelEditCommand}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
