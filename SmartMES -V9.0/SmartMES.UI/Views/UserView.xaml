<UserControl x:Class="SmartMES.UI.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 左：登录面板 -->
        <StackPanel Grid.Column="0">
            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="👤 当前登录" Style="{StaticResource HeadingText}"/>
                    <TextBlock Text="{Binding CurrentUser.DisplayName, FallbackValue='未登录'}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding RoleText, StringFormat='角色: {0}'}" Style="{StaticResource SecondaryText}"/>
                    <TextBlock Text="{Binding CurrentUser.LastLoginAt, StringFormat='登录时间: {0:HH:mm:ss}', FallbackValue=''}"
                               Style="{StaticResource SecondaryText}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="🔐 用户登录" Style="{StaticResource HeadingText}"/>
                    <TextBlock Text="用户名" Style="{StaticResource SecondaryText}" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="密码" Style="{StaticResource SecondaryText}" Margin="0,0,0,2"/>
                    <PasswordBox x:Name="PwdBox" Margin="0,0,0,10"
                                 PasswordChanged="PwdBox_PasswordChanged"/>
                    <TextBlock Text="{Binding LoginMessage}" Foreground="{StaticResource AccentOrangeBrush}"
                               FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🔓 登录" Style="{StaticResource SuccessButton}"
                                Command="{Binding LoginCommand}" Width="90" Margin="0,0,8,0"/>
                        <Button Content="🚪 登出" Style="{StaticResource DangerButton}"
                                Command="{Binding LogoutCommand}" Width="90"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="📋 内置账号" Style="{StaticResource HeadingText}"/>
                    <TextBlock Text="admin / admin123 → 管理员（全权限）"    Style="{StaticResource SecondaryText}" Margin="0,4,0,2"/>
                    <TextBlock Text="operator / op123 → 操作员"              Style="{StaticResource SecondaryText}" Margin="0,2"/>
                    <TextBlock Text="viewer / view123 → 只读观察者"          Style="{StaticResource SecondaryText}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 中：用户列表（仅Admin可操作）-->
        <Border Grid.Column="2" Style="{StaticResource CardPanel}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="👥 用户列表" Style="{StaticResource HeadingText}" Margin="12,8"/>
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,8"
                           IsEnabled="{Binding IsAdmin}">
                    <Button Content="➕ 新增" Style="{StaticResource SuccessButton}" Command="{Binding NewUserCommand}" Margin="0,0,6,0"/>
                    <Button Content="🗑 删除" Style="{StaticResource DangerButton}"  Command="{Binding DeleteUserCommand}"/>
                    <TextBlock Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"
                               Text="⚠ 仅管理员可管理用户" Foreground="{StaticResource AccentOrangeBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </WrapPanel>
                <DataGrid Grid.Row="2" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                          IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="用户名"   Binding="{Binding Username}"    Width="100"/>
                        <DataGridTextColumn Header="显示名"   Binding="{Binding DisplayName}" Width="90"/>
                        <DataGridTextColumn Header="角色"     Binding="{Binding Role}"        Width="80"/>
                        <DataGridTextColumn Header="启用"     Binding="{Binding IsActive}"    Width="55"/>
                        <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAt, StringFormat=HH:mm:ss}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 右：权限编辑面板 -->
        <Border Grid.Column="4" Style="{StaticResource CardPanel}" IsEnabled="{Binding IsAdmin}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🔑 权限编辑" Style="{StaticResource HeadingText}" Margin="0,0,0,8"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding IsEditing}">
                        <TextBlock Text="基本信息" Style="{StaticResource SecondaryText}" Margin="0,0,0,4" FontWeight="Bold"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="用户名" VerticalAlignment="Center" Style="{StaticResource SecondaryText}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.Username, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="显示名" VerticalAlignment="Center" Style="{StaticResource SecondaryText}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.DisplayName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="密码" VerticalAlignment="Center" Style="{StaticResource SecondaryText}"/>
                            <TextBox Grid.Column="1" Text="{Binding EditUser.Password, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock Text="页面权限" Style="{StaticResource SecondaryText}" FontWeight="Bold" Margin="0,0,0,6"/>
                        <CheckBox Content="仪表盘"    IsChecked="{Binding EditUser.Permissions.Dashboard}"     Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="设备管理"  IsChecked="{Binding EditUser.Permissions.Device}"         Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="通信监控"  IsChecked="{Binding EditUser.Permissions.Communication}"   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="报警管理"  IsChecked="{Binding EditUser.Permissions.Alarm}"           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="系统日志"  IsChecked="{Binding EditUser.Permissions.Log}"             Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="自动化流程" IsChecked="{Binding EditUser.Permissions.Automation}"     Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="MES通信"   IsChecked="{Binding EditUser.Permissions.MesComm}"        Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="文件处理"  IsChecked="{Binding EditUser.Permissions.FileProcess}"    Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="数据库"    IsChecked="{Binding EditUser.Permissions.Database}"        Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="运动控制"  IsChecked="{Binding EditUser.Permissions.Motion}"          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="C++ Native" IsChecked="{Binding EditUser.Permissions.Native}"        Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="10轴运动样例" IsChecked="{Binding EditUser.Permissions.Motion10Axis}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="视觉样例"  IsChecked="{Binding EditUser.Permissions.Vision}"          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="视觉+运动协同" IsChecked="{Binding EditUser.Permissions.VisionMotion}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="工业系统总览" IsChecked="{Binding EditUser.Permissions.Industrial}"    Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>
                        <CheckBox Content="参数配置" IsChecked="{Binding EditUser.Permissions.Settings}"        Foreground="{StaticResource AccentOrangeBrush}" Margin="0,2"/>
                        <CheckBox Content="用户管理" IsChecked="{Binding EditUser.Permissions.UserManage}"      Foreground="{StaticResource AccentOrangeBrush}" Margin="0,2"/>
                    </StackPanel>
                </ScrollViewer>

                <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="✅ 保存" Style="{StaticResource SuccessButton}" Command="{Binding SaveUserCommand}"   Margin="0,0,8,0"/>
                    <Button Content="✏ 编辑" Style="{StaticResource OrangeButton}"  Command="{Binding NewUserCommand}"   Margin="0,0,8,0"/>
                    <Button Content="❌ 取消" Style="{StaticResource DangerButton}"  Command="{Binding CancelEditCommand}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
