<UserControl x:Class="SmartMES.UI.Modules.SecsGemModule.SecsGemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- ════════ 连接控制栏 ════════ -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="SECS/GEM 半导体通信" Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="主机:" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding HostAddress}" Width="120" Margin="0,0,8,0"/>

                <TextBlock Text="端口:" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Text="{Binding HostPort}" Width="60" Margin="0,0,12,0"/>

                <Button Content="连接" Style="{StaticResource PrimaryButton}" Command="{Binding ConnectCommand}" Margin="0,0,4,0"/>
                <Button Content="断开" Style="{StaticResource DangerButton}" Command="{Binding DisconnectCommand}" Margin="0,0,12,0"/>

                <Button Content="启用通信" Style="{StaticResource SuccessButton}" Command="{Binding EnableCommand}" Margin="0,0,4,0"/>
                <Button Content="请求上线" Style="{StaticResource PrimaryButton}" Command="{Binding GoOnlineCommand}" Margin="0,0,4,0"/>
                <Button Content="离线" Style="{StaticResource NavButton}" Command="{Binding GoOfflineCommand}" Margin="0,0,4,0"/>
                <Button Content="发送事件" Style="{StaticResource SuccessButton}" Command="{Binding SendEventCommand}" Margin="0,0,4,0"/>
                <Button Content="刷新数据" Style="{StaticResource NavButton}" Command="{Binding RefreshDataCommand}" Margin="0,0,4,0"/>

                <TextBlock Text="{Binding StatusText}" Foreground="#F59E0B" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ════════ 状态卡片 ════════ -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 连接状态 -->
                <StackPanel Grid.Column="0" Margin="8">
                    <TextBlock Text="连接状态" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="#3B82F6" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <!-- 通信状态 -->
                <StackPanel Grid.Column="1" Margin="8">
                    <TextBlock Text="通信状态 (E30)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding CommState}" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <!-- 控制状态 -->
                <StackPanel Grid.Column="2" Margin="8">
                    <TextBlock Text="控制状态 (E30)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding ControlState}" Foreground="#F59E0B" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <!-- 消息计数 -->
                <StackPanel Grid.Column="3" Margin="8">
                    <TextBlock Text="SECS 消息数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding MessageCount}" Foreground="#8B5CF6" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════ 数据区（SV / EC / PP） ════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 状态变量 SV -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="状态变量 (SV — S1F3/F4)" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding StatusVariables}" AutoGenerateColumns="False"
                              IsReadOnly="True" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                              RowBackground="#1E293B" AlternatingRowBackground="#1A2332" BorderThickness="0"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2E3A55"
                              HeadersVisibility="Column" CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SVID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="当前值" Binding="{Binding Value}" Width="100"/>
                            <DataGridTextColumn Header="单位" Binding="{Binding Units}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- 设备常量 EC -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="设备常量 (EC — S2F13/F15)" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding EquipmentConstants}" AutoGenerateColumns="False"
                              IsReadOnly="True" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                              RowBackground="#1E293B" AlternatingRowBackground="#1A2332" BorderThickness="0"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2E3A55"
                              HeadersVisibility="Column" CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ECID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="当前值" Binding="{Binding Value}" Width="100"/>
                            <DataGridTextColumn Header="单位" Binding="{Binding Units}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- 工艺程序 PP -->
            <Border Grid.Column="4" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="工艺程序 (PP — S7)" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding ProcessPrograms}" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                             FontFamily="Consolas" FontSize="13"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ════════ 通信日志 ════════ -->
        <Border Grid.Row="6" Style="{StaticResource CardPanel}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="SECS 消息日志" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"/>
                    <Button Content="清空" Style="{StaticResource DangerButton}" Command="{Binding ClearLogCommand}"
                            Margin="12,0,0,0" Padding="8,2"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Logs}" Background="Transparent"
                         Foreground="#A3E635" BorderThickness="0"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
