<UserControl x:Class="SmartMES.UI.Modules.IndustrialModule.IndustrialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- 顶部：状态机+安全+急停 -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <!-- 状态机 -->
                <Border CornerRadius="6" Padding="16,8" Background="{Binding SmBrush}" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SmText}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Button Content="▶ 启动" Style="{StaticResource SuccessButton}" Command="{Binding StartCmd}" Margin="0,0,6,0"/>
                <Button Content="⏸ 暂停" Style="{StaticResource OrangeButton}"  Command="{Binding PauseCmd}"  Margin="0,0,6,0"/>
                <Button Content="⏹ 停止" Style="{StaticResource PrimaryButton}" Command="{Binding StopCmd}"   Margin="0,0,6,0"/>
                <Button Content="⚠ 报警" Style="{StaticResource OrangeButton}"  Command="{Binding AlarmCmd}"  Margin="0,0,6,0"/>
                <Button Content="🔄 复位" Style="{StaticResource PrimaryButton}" Command="{Binding ResetCmd}"  Margin="0,0,16,0"/>
                <Button Content="🛑 急停" Style="{StaticResource DangerButton}"  Command="{Binding EStopCmd}"  Margin="0,0,6,0" FontWeight="Bold" Padding="16,7"/>
                <Button Content="解除急停" Style="{StaticResource OrangeButton}" Command="{Binding ClearEStopCmd}" Margin="0,0,20,0"/>
                <!-- 安全互锁 -->
                <CheckBox Content="安全门关闭" IsChecked="{Binding DoorClosed}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <CheckBox Content="气压正常"   IsChecked="{Binding AirOk}"     Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- 中间：四大面板 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 调度系统 -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="⏱ 调度系统" Style="{StaticResource HeadingText}" Margin="12,8"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Tasks}" IsReadOnly="True" AutoGenerateColumns="False" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="任务" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="60"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="70"/>
                            <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="45"/>
                            <DataGridTextColumn Header="下次" Binding="{Binding Next}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- IO系统 -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🔌 IO系统" Style="{StaticResource HeadingText}" Margin="12,8"/>
                    <Button Grid.Row="1" Content="切换DO00" Style="{StaticResource OrangeButton}" Command="{Binding ToggleDoCmd}" Margin="8,0,8,4" HorizontalAlignment="Left"/>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding IoItems}" IsReadOnly="True" AutoGenerateColumns="False" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="通道" Binding="{Binding Name}" Width="55"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="35"/>
                            <DataGridTextColumn Header="值"   Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 配方系统 -->
            <Border Grid.Column="4" Style="{StaticResource CardPanel}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📋 配方系统" Style="{StaticResource HeadingText}" Margin="12,8"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,6">
                        <ComboBox ItemsSource="{Binding RecipeNames}" SelectedItem="{Binding SelectedRecipeName}"
                                  Width="120" Margin="0,0,6,0"/>
                        <Button Content="切换" Style="{StaticResource SuccessButton}" Command="{Binding ActivateRecipeCmd}"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding RecipeParams}" IsReadOnly="True" AutoGenerateColumns="False" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="参数" Binding="{Binding Name}"  Width="80"/>
                            <DataGridTextColumn Header="值"   Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="单位" Binding="{Binding Unit}"  Width="45"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 追溯+插件 -->
            <Border Grid.Column="6" Style="{StaticResource CardPanel}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🔍 追溯 / 🧩 插件" Style="{StaticResource HeadingText}" Margin="12,8"/>
                    <WrapPanel Grid.Row="1" Margin="8,0,8,6">
                        <Button Content="生成追溯" Style="{StaticResource SuccessButton}" Command="{Binding AddTraceCmd}" Margin="0,0,6,0"/>
                        <Button Content="扫描插件" Style="{StaticResource PrimaryButton}" Command="{Binding ScanPluginsCmd}"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Traces}" IsReadOnly="True" AutoGenerateColumns="False" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SN"   Binding="{Binding SN}"     Width="*"/>
                            <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="40"/>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}"   Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部日志 -->
        <Border Grid.Row="4" Style="{StaticResource CardPanel}" Padding="8">
            <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentGreenBrush}"/>
        </Border>
    </Grid>
</UserControl>
