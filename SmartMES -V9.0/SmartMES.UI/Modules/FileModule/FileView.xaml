<UserControl x:Class="SmartMES.UI.Modules.FileModule.FileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <UserControl.Resources>
        <!-- 修复ComboBox下拉文字颜色 -->
        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Background"   Value="{StaticResource BgLightBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgMidBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#33008CFF"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 操作栏 -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="格式:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}"
                          Style="{StaticResource DarkComboBox}" Width="110" Margin="0,0,12,0"/>
                <Button Content="📂 导入文件" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ImportCommand}" Margin="0,0,8,0"/>
                <Button Content="💾 导出示例数据" Style="{StaticResource SuccessButton}"
                        Command="{Binding ExportCommand}" Margin="0,0,8,0"/>
                <Button Content="📊 批量导出(全格式)" Style="{StaticResource OrangeButton}"
                        Command="{Binding ExportAllCommand}"/>
            </WrapPanel>
        </Border>

        <!-- 状态 -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                       FontFamily="Consolas" TextWrapping="Wrap"/>
        </Border>

        <!-- 预览 -->
        <Border Grid.Row="4" Style="{StaticResource CardPanel}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8">
                    <TextBlock Text="📄 文件预览" Style="{StaticResource HeadingText}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding PreviewInfo}" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewTable}"
                          IsReadOnly="True" AutoGenerateColumns="True"
                          CanUserAddRows="False" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0"
                          AlternatingRowBackground="{StaticResource BgLightBrush}">
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
