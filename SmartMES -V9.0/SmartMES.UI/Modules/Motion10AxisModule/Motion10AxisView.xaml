<UserControl x:Class="SmartMES.UI.Modules.Motion10AxisModule.Motion10AxisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="模式:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <CheckBox Content="循环模式" IsChecked="{Binding IsLoopMode}" VerticalAlignment="Center"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ModeText}" VerticalAlignment="Center" FontFamily="Consolas"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>

                    <TextBlock Text="循环次数:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Cycles, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,12,0" IsEnabled="{Binding IsLoopMode}"/>

                    <Button Content="▶ 执行程序" Style="{StaticResource SuccessButton}" Command="{Binding RunProgramCommand}" Margin="0,0,6,0"/>
                    <Button Content="🏠 全部回零" Style="{StaticResource PrimaryButton}" Command="{Binding HomeAllCommand}" Margin="0,0,6,0"/>
                    <Button Content="📄 载入示例" Style="{StaticResource OrangeButton}" Command="{Binding LoadSampleCommand}" Margin="0,0,6,0"/>
                    <Button Content="🔄 复位" Style="{StaticResource OrangeButton}" Command="{Binding ResetCommand}" Margin="0,0,6,0"/>
                    <Button Content="🛑 急停" Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" FontWeight="Bold" Padding="16,7"/>
                </WrapPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="状态: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"
                               MaxWidth="220" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                    <TextBlock Text="布局: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LayoutModeText}" Foreground="{StaticResource AccentGreenBrush}"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="🔢 G代码程序编辑器" Style="{StaticResource HeadingText}" Margin="0,0,0,6"/>
                        <TextBlock Style="{StaticResource SecondaryText}" FontSize="10" TextWrapping="Wrap">
                            支持指令: G0(快速定位) G1(线性进给) G28(回零) M0(暂停) M2(结束)
                        </TextBlock>
                        <TextBlock Style="{StaticResource SecondaryText}" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0">
                            轴名: X Y Z A B C U V W S | F=进给速度(mm/min)
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="4">
                    <TextBox Text="{Binding GCode, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="{StaticResource AccentGreenBrush}"
                             Background="#111318"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             SpellCheck.IsEnabled="False"/>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="执行行数" Style="{StaticResource SecondaryText}"/>
                            <TextBlock Text="{Binding ExecutedLines}" Foreground="{StaticResource AccentBrush}"
                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="运行时间" Style="{StaticResource SecondaryText}"/>
                            <TextBlock Text="{Binding ElapsedText}" Foreground="{StaticResource AccentGreenBrush}"
                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="12,8,12,6" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="⚙ 10轴实时状态" Style="{StaticResource HeadingText}" VerticalAlignment="Center"/>
                            <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="5×2布局" Style="{StaticResource PrimaryButton}" Command="{Binding Layout52Command}" Margin="0,0,6,0" Padding="10,4"/>
                                <Button Content="2×5布局" Style="{StaticResource OrangeButton}" Command="{Binding Layout25Command}" Padding="10,4"/>
                            </WrapPanel>
                        </DockPanel>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}" Margin="4,0,4,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="{Binding AxisPanelColumns}" Rows="{Binding AxisPanelRows}"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardPanel}" Margin="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <Border CornerRadius="3" Padding="5,2"
                                                        Background="{Binding StateBrush}" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StateText}" Foreground="White"
                                                               FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PositionText}"
                                                       FontFamily="Consolas" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding TargetText}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <ProgressBar Value="{Binding PositionClamped}"
                                                         Maximum="500" Minimum="0"
                                                         Height="3" Margin="0,3,0,0"
                                                         Background="#2E3240"
                                                         Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="8">
                    <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"
                             Foreground="{StaticResource AccentGreenBrush}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
