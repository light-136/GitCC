<UserControl x:Class="SmartMES.UI.Modules.VisionMotionModule.VisionMotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="周期数:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                <TextBox Text="{Binding Cycles, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,12,0"/>
                <Button Content="▶ 启动生产" Style="{StaticResource SuccessButton}" Command="{Binding StartCommand}"  Margin="0,0,8,0"/>
                <Button Content="🛑 急停"   Style="{StaticResource DangerButton}"  Command="{Binding StopCommand}"   Margin="0,0,8,0" FontWeight="Bold"/>
                <Button Content="🔄 复位"   Style="{StaticResource OrangeButton}"  Command="{Binding ResetCommand}"  Margin="0,0,20,0"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" FontFamily="Consolas" FontSize="13"/>
                <TextBlock Text="  |  " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalStats}" Foreground="{StaticResource AccentGreenBrush}"
                           VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold"/>
            </WrapPanel>
        </Border>

        <!-- 工位状态卡片 -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stations}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardPanel}" Margin="6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Border CornerRadius="4" Padding="10,4" Background="{Binding StateBrush}" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StateText}" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="OK: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding OkCount}" Foreground="#39D353" FontWeight="Bold" Margin="0,0,12,0"/>
                                <TextBlock Text="NG: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding NgCount}" Foreground="#FF4757" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LogText}" FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="40"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 9轴状态（3工位×XYZ）-->
        <Border Grid.Row="4" Style="{StaticResource CardPanel}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="⚙ 工位轴实时状态（3工位×XYZ）" Style="{StaticResource HeadingText}" Margin="12,8"/>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}" Margin="4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="9"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardPanel}" Margin="3">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,4,0"/>
                                        <Border CornerRadius="3" Padding="4,1" Background="{Binding StateBrush}">
                                            <TextBlock Text="{Binding StateText}" Foreground="White" FontSize="9"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding PositionText}" FontFamily="Consolas" FontSize="11"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <ProgressBar Value="{Binding PositionClamped}" Maximum="500"
                                                 Height="3" Margin="0,2,0,0"
                                                 Background="#2E3240" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 事件日志 -->
        <Border Grid.Row="6" Style="{StaticResource CardPanel}" Padding="8">
            <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentGreenBrush}"/>
        </Border>
    </Grid>
</UserControl>
