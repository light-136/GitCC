<UserControl x:Class="SmartMES.UI.Modules.NativeModule.NativeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左：控制面板 -->
        <Border Grid.Column="0" Style="{StaticResource CardPanel}">
            <StackPanel>
                <TextBlock Text="⚡ C++ Native 互调用" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding NativeVersion}" FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                <Button Content="🔍 检测DLL版本"    Style="{StaticResource PrimaryButton}" Command="{Binding CheckVersionCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                <Button Content="📊 统计计算"        Style="{StaticResource PrimaryButton}" Command="{Binding StatisticsCommand}" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                <Button Content="🔢 矩阵乘法(3×3)"  Style="{StaticResource OrangeButton}"  Command="{Binding MatrixCommand}"    Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                <Button Content="〰 移动平均滤波"   Style="{StaticResource SuccessButton}" Command="{Binding FilterCommand}"    Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                <Button Content="🔤 字符串处理"      Style="{StaticResource PrimaryButton}" Command="{Binding StringCommand}"    Margin="0,0,0,16" HorizontalAlignment="Stretch"/>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="📝 说明" Style="{StaticResource SecondaryText}" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryText}" FontSize="11">
                    C++ DLL通过P/Invoke调用。
                    若DLL未编译，按钮仍可点击但会显示降级结果。
                    编译方法：在SmartMES.Native目录运行 build.ps1
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 右：结果 + 日志 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="计算结果" Style="{StaticResource HeadingText}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ResultText}" FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="8">
                <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas" FontSize="11"
                         Foreground="{StaticResource AccentGreenBrush}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
