<UserControl x:Class="SmartMES.UI.Modules.MotionModule.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="🏠 全部回零"  Style="{StaticResource PrimaryButton}"  Command="{Binding HomeAllCommand}"      Margin="0,0,6,0"/>
                    <Button Content="▶ 随机移动"  Style="{StaticResource SuccessButton}"  Command="{Binding MoveAllCommand}"      Margin="0,0,6,0"/>
                    <Button Content="⏸ 全部暂停"  Style="{StaticResource OrangeButton}"   Command="{Binding PauseAllCommand}"     Margin="0,0,6,0"/>
                    <Button Content="▶ 全部恢复"  Style="{StaticResource PrimaryButton}"  Command="{Binding ResumeAllCommand}"    Margin="0,0,6,0"/>
                    <Button Content="🔗 线性插补"  Style="{StaticResource PrimaryButton}"  Command="{Binding LinearInterpCommand}" Margin="0,0,6,0"/>
                    <Button Content="🔄 复位"      Style="{StaticResource OrangeButton}"   Command="{Binding ResetAllCommand}"     Margin="0,0,16,0"/>
                    <Button Content="🛑 急停"      Style="{StaticResource DangerButton}"   Command="{Binding EStopCommand}"        FontWeight="Bold" Padding="16,7"/>
                </WrapPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="已就绪轴: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AxisCount}" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0,16,0"/>
                    <TextBlock Text="插补: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding InterpolStatus}" Foreground="{StaticResource AccentGreenBrush}" FontSize="12" FontFamily="Consolas" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="🌐 全局速度:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Value="{Binding GlobalSpeed}" Minimum="10" Maximum="500"
                        Width="140" VerticalAlignment="Center" Margin="0,0,6,0"
                        SmallChange="10" LargeChange="50"/>
                <TextBlock Text="{Binding GlobalSpeedText}" Foreground="{StaticResource AccentBrush}"
                           FontFamily="Consolas" FontSize="12" Width="80" VerticalAlignment="Center" Margin="0,0,24,0"/>

                <TextBlock Text="⚡ 全局加速度:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Value="{Binding GlobalAccel}" Minimum="100" Maximum="2000"
                        Width="140" VerticalAlignment="Center" Margin="0,0,6,0"
                        SmallChange="50" LargeChange="200"/>
                <TextBlock Text="{Binding GlobalAccelText}" Foreground="{StaticResource AccentOrangeBrush}"
                           FontFamily="Consolas" FontSize="12" Width="100" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📍 快速预设位" Style="{StaticResource HeadingText}" Margin="0,0,0,8"/>
                    <TextBlock Text="一键进入工艺常用点位" Style="{StaticResource SecondaryText}"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="📦 上料位" Style="{StaticResource PrimaryButton}" Command="{Binding MoveToLoadPoseCommand}" Margin="0,0,8,0"/>
                    <Button Content="🛠 加工位" Style="{StaticResource SuccessButton}" Command="{Binding MoveToWorkPoseCommand}" Margin="0,0,8,0"/>
                    <Button Content="🛡 安全位" Style="{StaticResource OrangeButton}" Command="{Binding MoveToSafePoseCommand}"/>
                </WrapPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="上料位: X80 Y45 Z65" FontFamily="Consolas" Style="{StaticResource SecondaryText}" TextAlignment="Right"/>
                    <TextBlock Text="加工位: X220 Y180 Z25" FontFamily="Consolas" Style="{StaticResource SecondaryText}" TextAlignment="Right"/>
                    <TextBlock Text="安全位: X20 Y20 Z120" FontFamily="Consolas" Style="{StaticResource SecondaryText}" TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="6" ItemsSource="{Binding Axes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardPanel}" Margin="6">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                                        Background="{Binding StateBrush}">
                                    <TextBlock Text="{Binding StateText}" Foreground="White"
                                               FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="当前位置" Style="{StaticResource SecondaryText}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding PositionText}"
                                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,2"/>

                            <ProgressBar Value="{Binding PositionClamped}"
                                         Maximum="500" Minimum="0"
                                         Height="6" Margin="0,4,0,6"
                                         Background="#2E3240"
                                         Foreground="{StaticResource AccentBrush}"/>

                            <TextBlock Text="{Binding TargetText}"
                                       FontSize="12" FontFamily="Consolas"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="移至(mm):" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MoveTarget, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" Margin="0,0,6,0"
                                         FontFamily="Consolas" FontSize="12"/>
                                <Button Content="Go ▶" Style="{StaticResource SuccessButton}"
                                        Command="{Binding MoveCommand}"
                                        Padding="8,4" FontSize="11"/>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="回零" Style="{StaticResource PrimaryButton}" Command="{Binding HomeCommand}"   Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="暂停" Style="{StaticResource OrangeButton}"  Command="{Binding PauseCommand}"  Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="恢复" Style="{StaticResource SuccessButton}" Command="{Binding ResumeCommand}" Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="停止" Style="{StaticResource DangerButton}"  Command="{Binding StopCommand}"   Padding="8,4" Margin="0,0,4,4"/>
                                <Button Content="复位" Style="{StaticResource OrangeButton}"  Command="{Binding ResetCommand}"  Padding="8,4"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="8" Style="{StaticResource CardPanel}" Padding="8">
            <ListBox ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                     FontFamily="Consolas" FontSize="11"
                     Foreground="{StaticResource AccentGreenBrush}"/>
        </Border>
    </Grid>
</UserControl>
