<UserControl x:Class="SmartMES.UI.Modules.VisionV2Module.VisionV2View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════ 工具栏 ════════ -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="视觉算法V2引擎" Foreground="{StaticResource AccentBrush}"
                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Button Content="管线执行" Style="{StaticResource PrimaryButton}" Command="{Binding RunPipelineCommand}" Margin="0,0,4,0"/>
                <Button Content="模板匹配" Style="{StaticResource SuccessButton}" Command="{Binding RunMatchCommand}" Margin="0,0,4,0"/>
                <Button Content="Blob分析" Style="{StaticResource PrimaryButton}" Command="{Binding RunBlobCommand}" Margin="0,0,4,0"/>
                <Button Content="直方图" Style="{StaticResource NavButton}" Command="{Binding RunHistogramCommand}" Margin="0,0,4,0"/>
                <Button Content="测量工具" Style="{StaticResource NavButton}" Command="{Binding RunMeasureCommand}" Margin="0,0,4,0"/>
                <Button Content="9点标定" Style="{StaticResource NavButton}" Command="{Binding RunCalibCommand}" Margin="0,0,4,0"/>

                <Separator Margin="8,0" Style="{x:Null}" Width="1" Background="{StaticResource BorderBrush}"/>

                <Button Content="一键全部运行" Style="{StaticResource SuccessButton}" Command="{Binding RunAllCommand}" Margin="4,0,8,0"/>
                <Button Content="清空日志" Style="{StaticResource DangerButton}" Command="{Binding ClearLogCommand}" Margin="0,0,8,0"/>

                <TextBlock Text="{Binding StatusText}" Foreground="#F59E0B" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ════════ 算法结果卡片 ════════ -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="6">
                    <TextBlock Text="管线执行" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding PipelineResult}" Foreground="#3B82F6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="6">
                    <TextBlock Text="模板匹配(NCC)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding MatchResult}" Foreground="#10B981" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="6">
                    <TextBlock Text="Blob分析(CCL)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding BlobResult}" Foreground="#F59E0B" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="6">
                    <TextBlock Text="直方图/OTSU" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding HistogramInfo}" Foreground="#8B5CF6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="6">
                    <TextBlock Text="测量工具" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding MeasureResult}" Foreground="#EC4899" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="6">
                    <TextBlock Text="9点标定" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding CalibResult}" Foreground="#F97316" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════ 主内容区 ════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：管线步骤 + 参数 -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="处理管线步骤" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <TextBlock Text="测试图像参数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="宽度:" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Width="40"/>
                            <TextBox Text="{Binding ImageWidth}" Width="60"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="高度:" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Width="40"/>
                            <TextBox Text="{Binding ImageHeight}" Width="60"/>
                        </StackPanel>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding PipelineSteps}" Background="Transparent"
                             Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12"/>
                </DockPanel>
            </Border>

            <!-- 右侧：算法日志 -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="算法执行日志" Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                    <ListBox ItemsSource="{Binding Logs}" Background="Transparent"
                             Foreground="#A3E635" BorderThickness="0"
                             FontFamily="Consolas" FontSize="11"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
