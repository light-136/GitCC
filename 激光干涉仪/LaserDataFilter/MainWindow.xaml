<Window x:Class="LaserDataFilter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="激光干涉仪数据筛选工具" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter Panel -->
        <GroupBox Grid.Row="0" Header="筛选条件" Padding="10" Margin="0,0,0,10">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="数据源目录：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtDataPath" Width="250" VerticalAlignment="Center" Margin="0,0,15,0" IsReadOnly="True"/>
                <Button x:Name="BtnBrowse" Content="浏览..." Width="60" Click="BtnBrowse_Click" Margin="0,0,30,0"/>

                <TextBlock Text="检测规格系列：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CmbSeries" Width="180" Margin="0,0,15,0" SelectionChanged="CmbSeries_SelectionChanged"/>

                <TextBlock Text="筛选日期：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="DpDate" Width="150" Margin="0,0,15,0"/>

                <Button x:Name="BtnFilter" Content="筛选" Width="80" Height="28" Click="BtnFilter_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnExport" Content="导出CSV" Width="80" Height="28" Click="BtnExport_Click" IsEnabled="False"/>
            </WrapPanel>
        </GroupBox>

        <!-- Data Preview -->
        <DataGrid x:Name="DgPreview" Grid.Row="1" AutoGenerateColumns="True"
                  IsReadOnly="True" CanUserAddRows="False"
                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
