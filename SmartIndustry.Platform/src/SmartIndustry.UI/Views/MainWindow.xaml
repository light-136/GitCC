<Window x:Class="SmartIndustry.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartIndustry Platform"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <!-- 导航按钮样式 -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#1565C0">
            <Grid>
                <TextBlock Text="⚙ SmartIndustry Platform"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
                <TextBlock x:Name="txtCurrentPage" Text="仪表盘"
                           Foreground="#BBDEFB" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航面板 -->
            <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,12">
                        <TextBlock Text="功能导航" FontSize="11" Foreground="#999"
                                   FontWeight="SemiBold" Margin="12,0,0,8"/>
                        <Button Content="📊 仪表盘" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="仪表盘"/>
                        <Button Content="🔧 运动控制" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="运动控制"/>
                        <Button Content="📷 视觉检测" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="视觉检测"/>
                        <Button Content="🔌 IO监控" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="IO监控"/>
                        <Button Content="📡 通信管理" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="通信管理"/>
                        <Button Content="📋 配方管理" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="配方管理"/>
                        <Button Content="⚠ 报警日志" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="报警日志"/>
                        <Button Content="📝 日志管理" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="日志管理"/>
                        <Button Content="⚙ 系统设置" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click" Tag="系统设置"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧内容区域 -->
            <Border Grid.Column="1">
                <ContentControl x:Name="contentArea"/>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#263238">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0"/>
                    <TextBlock Text="就绪" Foreground="#A5D6A7" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#546E7A" VerticalAlignment="Center"/>
                    <TextBlock Text="模拟模式" Foreground="#FFF176" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="SmartIndustry Platform v1.0"
                           Foreground="#78909C" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
