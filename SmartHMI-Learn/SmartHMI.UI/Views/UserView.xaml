<UserControl x:Class="SmartHMI.UI.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- User List -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="用户列表" Style="{StaticResource SectionHeader}"/>
                <DataGrid ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          IsReadOnly="True" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="显示名" Binding="{Binding DisplayName}" Width="120"/>
                        <DataGridTextColumn Header="角色" Binding="{Binding Role}" Width="100"/>
                        <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAt, StringFormat={}{0:MM-dd HH:mm}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Content="删除用户" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteUserCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Add User Panel -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="新建用户" Style="{StaticResource SectionHeader}"/>

                <Label Content="用户名 *"/>
                <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <Label Content="密码 *"/>
                <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <Label Content="显示名"/>
                <TextBox Text="{Binding NewDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <Label Content="角色"/>
                <ComboBox ItemsSource="{Binding RoleValues}"
                          SelectedItem="{Binding NewRole}" Margin="0,0,0,16"/>

                <Button Content="创建用户" Style="{StaticResource AccentButton}"
                        Command="{Binding AddUserCommand}" Height="36"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentGreen}"
                           FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
