<UserControl x:Class="SmartHMI.UI.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Controls -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="使能所有轴" Style="{StaticResource SuccessButton}"
                            Command="{Binding EnableAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="全轴回零" Style="{StaticResource AccentButton}"
                            Command="{Binding HomeAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="复位" Style="{StaticResource BaseButton}"
                            Command="{Binding ResetCommand}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentCyan}"
                               VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
                <Button Grid.Column="1" Content="⚠ 急停" Style="{StaticResource DangerButton}"
                        Command="{Binding EStopCommand}" Width="100" Height="36" FontSize="14" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Move To Position -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="定位移动" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="X:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding TargetX, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}"/>
                    <Label Grid.Column="3" Content="Y:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" Text="{Binding TargetY, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}"/>
                    <Label Grid.Column="6" Content="Z:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="7" Text="{Binding TargetZ, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}"/>
                    <Button Grid.Column="9" Content="移动" Style="{StaticResource AccentButton}"
                            Command="{Binding MoveToCommand}" Width="80"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Axis Panels -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- X Axis -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel DataContext="{Binding AxisX}">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="位置" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Position, StringFormat={}{0:F2} mm}"
                                       Foreground="{StaticResource AccentCyan}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="速度" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Velocity, StringFormat={}{0:F1} mm/s}"
                                       Foreground="{StaticResource AccentAmber}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8">
                        <Run Text="状态: "/>
                        <Run Text="{Binding State}" Foreground="{StaticResource TextPrimary}"/>
                        <Run Text="  使能: "/>
                        <Run Text="{Binding IsEnabled}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding FaultMessage}" Foreground="{StaticResource AccentRed}"
                               FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="◀ 点动-" Style="{StaticResource BaseButton}"
                                Command="{Binding JogMinusCommand}" Margin="0,0,4,0" Width="60"/>
                        <Button Content="停止" Style="{StaticResource BaseButton}"
                                Command="{Binding StopJogCommand}" Margin="0,0,4,0" Width="50"/>
                        <Button Content="点动+ ▶" Style="{StaticResource BaseButton}"
                                Command="{Binding JogPlusCommand}" Width="60"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Y Axis -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0">
                <StackPanel DataContext="{Binding AxisY}">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="位置" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Position, StringFormat={}{0:F2} mm}"
                                       Foreground="{StaticResource AccentCyan}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="速度" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Velocity, StringFormat={}{0:F1} mm/s}"
                                       Foreground="{StaticResource AccentAmber}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8">
                        <Run Text="状态: "/>
                        <Run Text="{Binding State}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding FaultMessage}" Foreground="{StaticResource AccentRed}"
                               FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="◀ 点动-" Style="{StaticResource BaseButton}"
                                Command="{Binding JogMinusCommand}" Margin="0,0,4,0" Width="60"/>
                        <Button Content="停止" Style="{StaticResource BaseButton}"
                                Command="{Binding StopJogCommand}" Margin="0,0,4,0" Width="50"/>
                        <Button Content="点动+ ▶" Style="{StaticResource BaseButton}"
                                Command="{Binding JogPlusCommand}" Width="60"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Z Axis -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel DataContext="{Binding AxisZ}">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="位置" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Position, StringFormat={}{0:F2} mm}"
                                       Foreground="{StaticResource AccentCyan}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="速度" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding Velocity, StringFormat={}{0:F1} mm/s}"
                                       Foreground="{StaticResource AccentAmber}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8">
                        <Run Text="状态: "/>
                        <Run Text="{Binding State}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding FaultMessage}" Foreground="{StaticResource AccentRed}"
                               FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="◀ 点动-" Style="{StaticResource BaseButton}"
                                Command="{Binding JogMinusCommand}" Margin="0,0,4,0" Width="60"/>
                        <Button Content="停止" Style="{StaticResource BaseButton}"
                                Command="{Binding StopJogCommand}" Margin="0,0,4,0" Width="50"/>
                        <Button Content="点动+ ▶" Style="{StaticResource BaseButton}"
                                Command="{Binding JogPlusCommand}" Width="60"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
