<UserControl x:Class="SmartHMI.UI.Views.TraceabilityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 搜索栏 -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="序列号:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchSerial, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="查询" Style="{StaticResource AccentButton}" Command="{Binding SearchBySerialCommand}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="3" Text="工单号:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="4" Text="{Binding SearchWorkorder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Column="5" Content="查询" Style="{StaticResource AccentButton}" Command="{Binding SearchByWorkorderCommand}" Margin="0,0,16,0"/>
                <Button Grid.Column="6" Content="最近100条" Style="{StaticResource BaseButton}" Command="{Binding LoadRecentCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="7" Content="添加示例" Style="{StaticResource BaseButton}" Command="{Binding AddSampleCommand}" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- 追溯记录列表 -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SectionHeader}"/>
                <DataGrid ItemsSource="{Binding Records}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工单号" Binding="{Binding WorkorderId}" Width="160"/>
                        <DataGridTextColumn Header="序列号" Binding="{Binding SerialNumber}" Width="160"/>
                        <DataGridTextColumn Header="产品类型" Binding="{Binding ProductType}" Width="100"/>
                        <DataGridTextColumn Header="事件类型" Binding="{Binding EventType}" Width="90"/>
                        <DataGridTextColumn Header="工序" Binding="{Binding StepName}" Width="120"/>
                        <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="60"/>
                        <DataGridTextColumn Header="操作员" Binding="{Binding OperatorId}" Width="80"/>
                        <DataGridTextColumn Header="工站" Binding="{Binding StationId}" Width="70"/>
                        <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm:ss}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
