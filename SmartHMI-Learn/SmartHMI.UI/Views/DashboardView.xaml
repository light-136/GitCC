<!--
    DashboardView.xaml — 仪表盘视图
    MVVM 说明：
      - DataContext = DashboardViewModel（由 App.xaml DataTemplate 自动绑定）
      - 所有数据通过 Binding 从 ViewModel 获取，无 code-behind 业务逻辑
      - 转换器使用全局 Styles.xaml 中注册的资源
-->
<UserControl x:Class="SmartHMI.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">
    <!-- 转换器已在 Styles.xaml 全局注册，无需在此重复声明 -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- KPI Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="在线设备" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding OnlineDeviceCount}" Style="{StaticResource ValueDisplay}"
                                   Foreground="{StaticResource AccentGreen}"/>
                        <TextBlock Text="台设备在线" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="活动报警" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="{Binding ActiveAlarmCount}" Style="{StaticResource ValueDisplay}"
                                   Foreground="{StaticResource AccentRed}"/>
                        <TextBlock Text="条未处理报警" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="温度 AI0" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding Ai0Value, StringFormat={}{0:F1}}"
                                       Style="{StaticResource ValueDisplay}" Foreground="{StaticResource AccentAmber}"/>
                            <TextBlock Text=" °C" Foreground="{StaticResource AccentAmber}"
                                       FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding Ai0Value}" Maximum="100" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="压力 AI1" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding Ai1Value, StringFormat={}{0:F1}}"
                                       Style="{StaticResource ValueDisplay}" Foreground="{StaticResource AccentCyan}"/>
                            <TextBlock Text=" bar" Foreground="{StaticResource AccentCyan}"
                                       FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding Ai1Value}" Maximum="100" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Second Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- DI Status -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="数字输入 (DI)" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding IoChannels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="3" Padding="8,4" CornerRadius="4" Width="68">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgPanel}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Value}" Value="True">
                                                        <Setter Property="Background" Value="#0A4A2A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="10"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Value, Converter={StaticResource BoolToOnOff}}"
                                                       FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Value}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Device Status -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="设备状态" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding DeviceStatuses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                        <Ellipse Grid.Column="1" Width="8" Height="8" Margin="8,0" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusColor}}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Grid.Column="2" Text="{Binding Status}"
                                                   Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Alarms -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="最近报警" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="暂无活动报警" Foreground="{StaticResource TextSecondary}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding RecentAlarms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" CornerRadius="4" Background="{StaticResource BgPanel}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Code}"
                                                   Foreground="{StaticResource AccentAmber}" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                   Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TriggeredAt, StringFormat={}{0:HH:mm:ss}}"
                                                   Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
