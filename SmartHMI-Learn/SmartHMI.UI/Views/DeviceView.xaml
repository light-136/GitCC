<!--
    DeviceView.xaml — 设备管理视图
    MVVM 说明：DataContext = DeviceViewModel，转换器使用全局资源
-->
<UserControl x:Class="SmartHMI.UI.Views.DeviceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="连接设备" Style="{StaticResource AccentButton}"
                    Command="{Binding ConnectCommand}" Margin="0,0,8,0"/>
            <Button Content="断开连接" Style="{StaticResource BaseButton}"
                    Command="{Binding DisconnectCommand}" Margin="0,0,8,0"/>
            <Button Content="刷新" Style="{StaticResource BaseButton}"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <!-- Device List -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice}"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="状态" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusColor}}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="设备名称" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="IP 地址" Binding="{Binding IpAddress}" Width="130"/>
                <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="70"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="最后更新" Binding="{Binding LastUpdated, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Detail Panel -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="设备详情" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                        <Run Text="名称: "/>
                        <Run Text="{Binding SelectedDevice.Name}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0">
                        <Run Text="类型: "/>
                        <Run Text="{Binding SelectedDevice.Type}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="连接信息" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                        <Run Text="地址: "/>
                        <Run Text="{Binding SelectedDevice.IpAddress}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0">
                        <Run Text="端口: "/>
                        <Run Text="{Binding SelectedDevice.Port}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="运行状态" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
                        <Run Text="状态: "/>
                        <Run Text="{Binding SelectedDevice.Status}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0">
                        <Run Text="描述: "/>
                        <Run Text="{Binding SelectedDevice.Description}" Foreground="{StaticResource TextPrimary}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
