<UserControl x:Class="SmartHMI.UI.Views.CloudSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDark}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 配置与操作 -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" FontFamily="Consolas"/>
                <Button Grid.Column="1" Content="立即同步" Style="{StaticResource AccentButton}"
                        Command="{Binding FlushCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="加入测试数据" Style="{StaticResource BaseButton}"
                        Command="{Binding EnqueueTestCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="3" Content="刷新" Style="{StaticResource BaseButton}"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <!-- 状态 KPI -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="待同步队列" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="{Binding PendingCount}" Style="{StaticResource ValueDisplay}" Foreground="{StaticResource AccentAmber}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="状态" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentCyan}" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 同步历史 -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="同步历史" Style="{StaticResource SectionHeader}"/>
                <DataGrid ItemsSource="{Binding Records}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="120"/>
                        <DataGridTemplateColumn Header="状态" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Syncing">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentAmber}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="重试次数" Binding="{Binding RetryCount}" Width="70"/>
                        <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="200"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                        <DataGridTextColumn Header="同步时间" Binding="{Binding SyncedAt, StringFormat={}{0:HH:mm:ss}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
