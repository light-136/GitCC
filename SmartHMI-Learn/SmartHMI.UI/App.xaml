<!--
    App.xaml — 应用程序入口配置
    说明：移除 StartupUri，改为在 App.xaml.cs 的 OnStartup 中
          通过 DI 容器创建 MainWindow，支持构造函数注入。
    同时在此注册所有 ViewModel → View 的 DataTemplate 映射，
    实现标准 MVVM 视图定位（ViewLocator）模式。
-->
<Application x:Class="SmartHMI.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartHMI.UI.ViewModels"
             xmlns:views="clr-namespace:SmartHMI.UI.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 全局样式字典 -->
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!--
                MVVM ViewLocator：DataTemplate 映射
                WPF 会根据 ContentControl.Content 的类型自动选择对应模板渲染 View。
                这样 MainViewModel 只需切换 CurrentViewModel 属性，
                界面就会自动切换到对应的 View，无需 code-behind 手动 new View()。
            -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DeviceViewModel}">
                <views:DeviceView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CommunicationViewModel}">
                <views:CommunicationView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MotionViewModel}">
                <views:MotionView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AlarmViewModel}">
                <views:AlarmView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LogViewModel}">
                <views:LogView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UserViewModel}">
                <views:UserView/>
            </DataTemplate>
            <!-- 第3-5阶段 -->
            <DataTemplate DataType="{x:Type vm:SafetyViewModel}">
                <views:SafetyView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VisionViewModel}">
                <views:VisionView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RecipeViewModel}">
                <views:RecipeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TraceabilityViewModel}">
                <views:TraceabilityView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportViewModel}">
                <views:ReportView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MesViewModel}">
                <views:MesView/>
            </DataTemplate>
            <!-- 第6阶段 -->
            <DataTemplate DataType="{x:Type vm:CloudSyncViewModel}">
                <views:CloudSyncView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SecsGemViewModel}">
                <views:SecsGemView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AiAssistantViewModel}">
                <views:AiAssistantView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
