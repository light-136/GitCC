<Window x:Class="SmartSemiCon.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartSemiCon.UI.ViewModels"
        xmlns:conv="clr-namespace:SmartSemiCon.UI.Converters"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding Title}"
        Height="900" Width="1440"
        WindowState="Maximized"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <!-- 页面可见性转换器 -->
        <conv:PageVisibilityConverter x:Key="PageVisibilityConverter"/>

        <!-- 导航按钮样式 -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource HeaderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Title}"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="16,0"/>

                <!-- 设备状态指示 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                    <Ellipse Width="12" Height="12" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding DeviceStateColor}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding DeviceStateText}"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 报警计数 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="报警:" Foreground="#FFB3B3" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveAlarmCount}"
                               Foreground="#FF5555" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0"/>
                </StackPanel>

                <!-- 用户信息 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,16,0">
                    <TextBlock Text="{Binding CurrentUserName}"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 左侧导航栏 -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource SidebarBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8">
                    <Button Content="  设备总览" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                    <Button Content="  运动控制" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Motion"/>
                    <Button Content="  视觉系统" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Vision"/>
                    <Button Content="  SECS/GEM" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="SecsGem"/>
                    <Button Content="  通讯监控" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Communication"/>

                    <Separator Margin="16,8" Background="{DynamicResource BorderBrush}"/>

                    <Button Content="  报警管理" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Alarm"/>
                    <Button Content="  配方管理" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Recipe"/>
                    <Button Content="  系统日志" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Log"/>
                    <Button Content="  系统设置" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"/>
                    <Button Content="  用户管理" Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}" CommandParameter="User"/>

                    <Separator Margin="16,8" Background="{DynamicResource BorderBrush}"/>

                    <!-- 快捷操作 -->
                    <Button Content="  初始化" Margin="8,4" Height="36"
                            Background="#2196F3" Foreground="White"
                            Command="{Binding InitializeDeviceCommand}"/>
                    <Button Content="  自动运行" Margin="8,4" Height="36"
                            Background="#4CAF50" Foreground="White"
                            Command="{Binding StartAutoCommand}"/>
                    <Button Content="  停止" Margin="8,4" Height="36"
                            Background="#FF9800" Foreground="White"
                            Command="{Binding StopDeviceCommand}"/>
                    <Button Content="  急停" Margin="8,4" Height="36"
                            Background="#F44336" Foreground="White" FontWeight="Bold"
                            Command="{Binding EmergencyStopCommand}"/>
                    <Button Content="  报警复位" Margin="8,4" Height="36"
                            Background="#9C27B0" Foreground="White"
                            Command="{Binding ResetAlarmsCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 主内容区域 -->
        <Border Grid.Row="1" Grid.Column="1" Margin="4">
            <Grid>
                <!-- 仪表盘页面 -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Dashboard}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- 状态卡片区域 -->
                    <WrapPanel Grid.Row="0" Margin="8">
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="180">
                            <StackPanel>
                                <TextBlock Text="设备状态" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding DeviceStateText}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="180">
                            <StackPanel>
                                <TextBlock Text="运动轴数" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding AxisCount}" FontSize="24" FontWeight="Bold" Foreground="#2196F3" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="180">
                            <StackPanel>
                                <TextBlock Text="相机数量" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding CameraCount}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="180">
                            <StackPanel>
                                <TextBlock Text="活跃报警" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding ActiveAlarmCount}" FontSize="24" FontWeight="Bold" Foreground="#F44336" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 视觉-运动协同演示区域 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="视觉-运动协同演示" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                            <WrapPanel Grid.Row="1">
                                <Button Content="9点标定演示" Command="{Binding RunCalibrationDemoCommand}"
                                        Margin="4" Padding="12,6" Background="#00BCD4" Foreground="White"/>
                                <Button Content="视觉对位演示" Command="{Binding RunAlignDemoCommand}"
                                        Margin="4" Padding="12,6" Background="#009688" Foreground="White"/>
                                <Button Content="生产流程模拟" Command="{Binding RunProductionDemoCommand}"
                                        Margin="4" Padding="12,6" Background="#3F51B5" Foreground="White" FontWeight="Bold"/>
                                <Border Background="#263238" CornerRadius="4" Padding="10,6" Margin="8,4,4,4">
                                    <TextBlock Foreground="#4CAF50">
                                        <Run Text="状态: "/><Run Text="{Binding DemoStatus}" Foreground="#00E676"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#263238" CornerRadius="4" Padding="10,6" Margin="4">
                                    <TextBlock Foreground="#81D4FA">
                                        <Run Text="标定: "/><Run Text="{Binding CalibrationInfo}" Foreground="#40C4FF"/>
                                    </TextBlock>
                                </Border>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <!-- 轴状态列表 -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="运动轴状态" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}" Margin="8,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding AxisStatuses}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" BorderThickness="0"
                                      RowBackground="{DynamicResource CardBrush}"
                                      AlternatingRowBackground="{DynamicResource AlternateRowBrush}"
                                      Foreground="{DynamicResource TextBrush}"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="轴ID" Binding="{Binding AxisId}" Width="60"/>
                                    <DataGridTextColumn Header="位置(mm)" Binding="{Binding Position, StringFormat=F3}" Width="120"/>
                                    <DataGridTextColumn Header="速度(mm/s)" Binding="{Binding Velocity, StringFormat=F1}" Width="100"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="使能" Binding="{Binding IsServoOn}" Width="60"/>
                                    <DataGridCheckBoxColumn Header="已回原" Binding="{Binding IsHomed}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- 日志面板 -->
                    <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="系统日志" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}" Margin="8,4"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource TextBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Foreground="#888"/>
                                            <Run Text=" ["/>
                                            <Run Text="{Binding Level}" Foreground="#4CAF50"/>
                                            <Run Text="] "/>
                                            <Run Text="{Binding Source}" Foreground="#2196F3"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding Message}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== 运动控制页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Motion}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>

                    <!-- 基本操作面板 -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="选择轴:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MotionVm.SelectedAxisId, UpdateSourceTrigger=PropertyChanged}" Width="60" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="目标位置:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MotionVm.TargetPosition, UpdateSourceTrigger=PropertyChanged}" Width="80" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="速度:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding MotionVm.MoveSpeed, UpdateSourceTrigger=PropertyChanged}" Width="60" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="JOG+" Command="{Binding MotionVm.JogPositiveCommand}" Margin="4,0" Background="#4CAF50" Foreground="White"/>
                            <Button Content="JOG-" Command="{Binding MotionVm.JogNegativeCommand}" Margin="4,0" Background="#FF9800" Foreground="White"/>
                            <Button Content="停止" Command="{Binding MotionVm.StopJogCommand}" Margin="4,0" Background="#F44336" Foreground="White"/>
                            <Button Content="绝对移动" Command="{Binding MotionVm.MoveAbsoluteCommand}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="相对移动" Command="{Binding MotionVm.MoveRelativeCommand}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="回原" Command="{Binding MotionVm.HomeAxisCommand}" Margin="4,0" Background="#9C27B0" Foreground="White"/>
                            <Button Content="全部回原" Command="{Binding MotionVm.HomeAllCommand}" Margin="4,0" Background="#9C27B0" Foreground="White"/>
                            <Button Content="使能" Command="{Binding MotionVm.ServoOnCommand}" Margin="4,0"/>
                            <Button Content="全部使能" Command="{Binding MotionVm.ServoOnAllCommand}" Margin="4,0"/>
                            <Button Content="全部急停" Command="{Binding MotionVm.EmergencyStopAllCommand}" Margin="4,0" Background="#D32F2F" Foreground="White" FontWeight="Bold"/>
                            <Button Content="刷新" Command="{Binding MotionVm.RefreshStatusCommand}" Margin="4,0"/>
                        </WrapPanel>
                    </Border>

                    <!-- 增强功能面板：插补运动 + 循环运动 + 点位示教 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 插补运动 -->
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="插补运动" FontSize="13" FontWeight="Bold" Foreground="#00BCD4" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="X轴:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.InterpAxisX}" Width="40" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="Y轴:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.InterpAxisY}" Width="40" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="距离:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.InterpDistance}" Width="50" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="直线插补" Command="{Binding MotionVm.LinearInterpolationCommand}" Margin="0,0,4,0" Padding="10,4" Background="#00BCD4" Foreground="White"/>
                                    <Button Content="圆弧插补" Command="{Binding MotionVm.ArcInterpolationCommand}" Margin="0,0,4,0" Padding="10,4" Background="#0097A7" Foreground="White"/>
                                </WrapPanel>
                            </StackPanel>

                            <!-- 循环运动 -->
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="循环运动" FontSize="13" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="起点:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.CycleStart}" Width="50" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="终点:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.CycleEnd}" Width="50" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                                        <TextBlock Text="次数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding MotionVm.CycleCount}" Width="40" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="开始循环" Command="{Binding MotionVm.StartCycleCommand}" Margin="0,0,4,0" Padding="10,4" Background="#FF9800" Foreground="White"/>
                                    <Button Content="停止循环" Command="{Binding MotionVm.StopCycleCommand}" Margin="0,0,4,0" Padding="10,4" Background="#F44336" Foreground="White"/>
                                    <TextBlock Text="{Binding MotionVm.CycleStatus}" VerticalAlignment="Center" Margin="8,0" Foreground="#FFC107"/>
                                </WrapPanel>
                            </StackPanel>

                            <!-- 点位示教 -->
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="点位示教" FontSize="13" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <Button Content="示教当前位置" Command="{Binding MotionVm.TeachCurrentPositionCommand}" Margin="0,0,4,4" Padding="10,4" Background="#4CAF50" Foreground="White"/>
                                    <Button Content="执行示教序列" Command="{Binding MotionVm.RunTeachSequenceCommand}" Margin="0,0,4,4" Padding="10,4" Background="#2196F3" Foreground="White"/>
                                    <Button Content="清空示教" Command="{Binding MotionVm.ClearTeachPointsCommand}" Margin="0,0,4,4" Padding="10,4"/>
                                    <Button Content="清空轨迹" Command="{Binding MotionVm.ClearTrajectoryCommand}" Margin="0,0,4,4" Padding="10,4"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding MotionVm.TeachPoints.Count, StringFormat=示教点: {0}个}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 轴状态 + 轨迹记录 双栏 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 轴状态表格 -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                            <DataGrid ItemsSource="{Binding MotionVm.AxisStatuses}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="轴ID" Binding="{Binding AxisId}" Width="60"/>
                                    <DataGridTextColumn Header="位置(mm)" Binding="{Binding Position, StringFormat=F3}" Width="120"/>
                                    <DataGridTextColumn Header="速度(mm/s)" Binding="{Binding Velocity, StringFormat=F1}" Width="100"/>
                                    <DataGridTextColumn Header="目标位置" Binding="{Binding TargetPosition, StringFormat=F3}" Width="120"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="使能" Binding="{Binding IsServoOn}" Width="60"/>
                                    <DataGridCheckBoxColumn Header="已回原" Binding="{Binding IsHomed}" Width="60"/>
                                    <DataGridCheckBoxColumn Header="正限位" Binding="{Binding IsPositiveLimit}" Width="60"/>
                                    <DataGridCheckBoxColumn Header="负限位" Binding="{Binding IsNegativeLimit}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- 轨迹记录 -->
                        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="运动轨迹记录" FontSize="13" FontWeight="Bold" Foreground="#00BCD4" Margin="4,2"/>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding MotionVm.Trajectory}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="90"/>
                                        <DataGridTextColumn Header="轴" Binding="{Binding AxisId}" Width="40"/>
                                        <DataGridTextColumn Header="位置(mm)" Binding="{Binding Position, StringFormat=F3}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 运动日志 -->
                    <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="运动日志" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="8,4"/>
                            <ListBox Grid.Row="1" ItemsSource="{Binding MotionVm.MotionLogs}" BorderThickness="0"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== 视觉系统页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Vision}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 基本操作面板 -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <TextBlock Text="相机ID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding VisionVm.SelectedCameraId}" Width="50" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="打开相机" Command="{Binding VisionVm.OpenCameraCommand}" Margin="4,0" Background="#4CAF50" Foreground="White"/>
                            <Button Content="关闭相机" Command="{Binding VisionVm.CloseCameraCommand}" Margin="4,0"/>
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <TextBlock Text="算法:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox ItemsSource="{Binding VisionVm.Algorithms}" SelectedItem="{Binding VisionVm.SelectedAlgorithm}" Width="140"/>
                            </StackPanel>
                            <Button Content="采集并检测" Command="{Binding VisionVm.CaptureAndInspectCommand}" Margin="8,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="全部相机采集" Command="{Binding VisionVm.CaptureAllCamerasCommand}" Margin="4,0" Background="#3F51B5" Foreground="White"/>
                            <Button Content="重置统计" Command="{Binding VisionVm.ResetStatisticsCommand}" Margin="4,0"/>
                        </WrapPanel>
                    </Border>

                    <!-- 增强功能面板：连续检测 + 相机参数 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 连续检测 -->
                            <StackPanel>
                                <TextBlock Text="连续检测模式" FontSize="13" FontWeight="Bold" Foreground="#00BCD4" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <TextBlock Text="间隔(ms):" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding VisionVm.ContinuousInterval}" Width="60" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="启动连续检测" Command="{Binding VisionVm.StartContinuousCommand}" Margin="0,0,4,0" Padding="10,4" Background="#00BCD4" Foreground="White"/>
                                    <Button Content="停止" Command="{Binding VisionVm.StopContinuousCommand}" Margin="0,0,4,0" Padding="10,4" Background="#F44336" Foreground="White"/>
                                    <TextBlock Text="{Binding VisionVm.ContinuousStatus}" VerticalAlignment="Center" Margin="8,0" Foreground="#FFC107"/>
                                </WrapPanel>
                            </StackPanel>

                            <!-- 相机参数 -->
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="相机参数" FontSize="13" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <TextBlock Text="曝光(us):" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding VisionVm.ExposureTime}" Width="60" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                        <TextBlock Text="增益:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding VisionVm.Gain}" Width="50" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="应用参数" Command="{Binding VisionVm.ApplyCameraParamsCommand}" Padding="10,4" Background="#FF9800" Foreground="White"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 统计卡片 -->
                    <WrapPanel Grid.Row="2" Margin="8">
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="总检测" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding VisionVm.TotalInspections}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="通过" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding VisionVm.PassCount}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="失败" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding VisionVm.FailCount}" FontSize="24" FontWeight="Bold" Foreground="#F44336"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="良率(%)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding VisionVm.PassRate, StringFormat=F1}" FontSize="24" FontWeight="Bold" Foreground="#2196F3"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 检测结果 -->
                    <Border Grid.Row="3" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding VisionVm.InspectionResult}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="8,4"/>
                            <TextBlock Grid.Row="1" Text="检测历史" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,8,8,4"/>
                            <DataGrid Grid.Row="2" ItemsSource="{Binding VisionVm.ResultHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss}" Width="80"/>
                                    <DataGridTextColumn Header="算法" Binding="{Binding Algorithm}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="通过" Binding="{Binding IsSuccess}" Width="60"/>
                                    <DataGridTextColumn Header="分数" Binding="{Binding Score, StringFormat=F2}" Width="80"/>
                                    <DataGridTextColumn Header="耗时(ms)" Binding="{Binding ProcessTimeMs}" Width="80"/>
                                    <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== SECS/GEM页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=SecsGem}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <WrapPanel>
                            <TextBlock Text="Host IP:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SecsGemVm.HostIp}" Width="120" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SecsGemVm.HostPort}" Width="60" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="连接" Command="{Binding SecsGemVm.ConnectCommand}" Margin="4,0" Background="#4CAF50" Foreground="White"/>
                            <Button Content="断开" Command="{Binding SecsGemVm.DisconnectCommand}" Margin="4,0" Background="#F44336" Foreground="White"/>
                            <Button Content="S1F1" Command="{Binding SecsGemVm.SendS1F1Command}" Margin="8,0,4,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="S1F13" Command="{Binding SecsGemVm.SendS1F13Command}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="S2F41" Command="{Binding SecsGemVm.SendS2F41Command}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                        </WrapPanel>
                    </Border>

                    <!-- 状态信息 -->
                    <WrapPanel Grid.Row="1" Margin="8">
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="连接状态" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding SecsGemVm.ConnectionState}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="控制状态" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding SecsGemVm.ControlState}" FontSize="18" FontWeight="Bold" Foreground="#2196F3"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="4" MinWidth="150">
                            <StackPanel>
                                <TextBlock Text="消息计数" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding SecsGemVm.MessageCount}" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- 消息日志 -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <DataGrid ItemsSource="{Binding SecsGemVm.MessageLog}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="100"/>
                                <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="60"/>
                                <DataGridTextColumn Header="消息" Binding="{Binding MessageId}" Width="80"/>
                                <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- ===================== 通讯监控页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Communication}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Text="服务端 端口:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding CommVm.ServerPort}" Width="60" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="启动服务端" Command="{Binding CommVm.StartServerCommand}" Margin="4,0" Background="#4CAF50" Foreground="White"/>
                                <Button Content="停止" Command="{Binding CommVm.StopServerCommand}" Margin="4,0"/>
                                <TextBlock Text="{Binding CommVm.ConnectedClientCount, StringFormat=已连接: {0}}" VerticalAlignment="Center" Margin="12,0" Foreground="#4CAF50"/>
                            </WrapPanel>
                            <WrapPanel>
                                <TextBlock Text="客户端 IP:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding CommVm.ClientHost}" Width="120" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding CommVm.ClientPort}" Width="60" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button Content="连接" Command="{Binding CommVm.ConnectClientCommand}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                                <Button Content="断开" Command="{Binding CommVm.DisconnectClientCommand}" Margin="4,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 发送区 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="发送" Command="{Binding CommVm.SendCommand}" Margin="8,0,0,0" Background="#2196F3" Foreground="White" Width="80"/>
                            <TextBox Text="{Binding CommVm.SendMessage, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                    </Border>

                    <!-- 通讯日志 -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <DataGrid ItemsSource="{Binding CommVm.CommLogs}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat=HH:mm:ss.fff}" Width="100"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="100"/>
                                <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- ===================== 报警管理页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Alarm}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <WrapPanel>
                            <Border Background="#FF9800" CornerRadius="4" Padding="12,6" Margin="4">
                                <TextBlock Foreground="White">
                                    <Run Text="警告: "/><Run Text="{Binding AlarmVm.WarningCount}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#F44336" CornerRadius="4" Padding="12,6" Margin="4">
                                <TextBlock Foreground="White">
                                    <Run Text="重故障: "/><Run Text="{Binding AlarmVm.HeavyCount}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#D32F2F" CornerRadius="4" Padding="12,6" Margin="4">
                                <TextBlock Foreground="White">
                                    <Run Text="致命: "/><Run Text="{Binding AlarmVm.FatalCount}"/>
                                </TextBlock>
                            </Border>
                            <Button Content="清除选中" Command="{Binding AlarmVm.ClearSelectedCommand}" Margin="12,0,4,0" Background="#9C27B0" Foreground="White"/>
                            <Button Content="全部清除" Command="{Binding AlarmVm.ClearAllCommand}" Margin="4,0" Background="#F44336" Foreground="White"/>
                            <Button Content="刷新" Command="{Binding AlarmVm.RefreshAlarmsCommand}" Margin="4,0"/>
                            <Button Content="测试报警" Command="{Binding AlarmVm.TriggerTestAlarmCommand}" Margin="4,0" Background="#FF9800" Foreground="White"/>
                            <Button Content="加载历史" Command="{Binding AlarmVm.LoadHistoryCommand}" Margin="4,0"/>
                        </WrapPanel>
                    </Border>

                    <!-- 活跃报警 -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="活跃报警" FontSize="14" FontWeight="Bold" Foreground="#F44336" Margin="8,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding AlarmVm.ActiveAlarms}" AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectedValue="{Binding AlarmVm.SelectedAlarmCode}" SelectedValuePath="AlarmCode">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="代码" Binding="{Binding AlarmCode}" Width="80"/>
                                    <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80"/>
                                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="100"/>
                                    <DataGridTextColumn Header="描述" Binding="{Binding Message}" Width="*"/>
                                    <DataGridTextColumn Header="触发时间" Binding="{Binding OccurredAt, StringFormat=HH:mm:ss}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- 历史报警 -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="历史报警" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" Margin="8,4"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding AlarmVm.AlarmHistory}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="代码" Binding="{Binding AlarmCode}" Width="80"/>
                                    <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80"/>
                                    <DataGridTextColumn Header="描述" Binding="{Binding Message}" Width="*"/>
                                    <DataGridTextColumn Header="触发" Binding="{Binding OccurredAt, StringFormat=MM-dd HH:mm}" Width="110"/>
                                    <DataGridTextColumn Header="清除" Binding="{Binding ClearedAt, StringFormat=MM-dd HH:mm}" Width="110"/>
                                    <DataGridTextColumn Header="操作员" Binding="{Binding ClearedBy}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== 配方管理页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Recipe}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 配方列表 -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="配方列表" FontSize="14" FontWeight="Bold" Margin="4"/>
                            <Button Grid.Row="1" Content="刷新" Command="{Binding RecipeVm.RefreshRecipeListAsyncCommand}" Margin="4"/>
                            <ListBox Grid.Row="2" ItemsSource="{Binding RecipeVm.RecipeNames}" SelectedItem="{Binding RecipeVm.CurrentRecipeName}" Margin="0,4"/>
                            <StackPanel Grid.Row="3">
                                <TextBox Text="{Binding RecipeVm.NewRecipeName, UpdateSourceTrigger=PropertyChanged}" Margin="4,2"/>
                                <Button Content="新建配方" Command="{Binding RecipeVm.CreateRecipeCommand}" Margin="4,2" Background="#4CAF50" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 配方编辑 -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <TextBlock Text="配方:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="{Binding RecipeVm.CurrentRecipeName}" VerticalAlignment="Center" FontSize="16" Foreground="#2196F3"/>
                                <Button Content="加载" Command="{Binding RecipeVm.LoadRecipeCommand}" CommandParameter="{Binding RecipeVm.CurrentRecipeName}" Margin="16,0,4,0"/>
                                <Button Content="保存" Command="{Binding RecipeVm.SaveRecipeCommand}" Margin="4,0" Background="#4CAF50" Foreground="White"/>
                                <Button Content="删除" Command="{Binding RecipeVm.DeleteRecipeCommand}" Margin="4,0" Background="#F44336" Foreground="White"/>
                            </WrapPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="备注:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding RecipeVm.RecipeDescription, UpdateSourceTrigger=PropertyChanged}" Width="400"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" ItemsSource="{Binding RecipeVm.Parameters}" AutoGenerateColumns="False" Margin="0,8,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="参数名" Binding="{Binding Key}" Width="200"/>
                                    <DataGridTextColumn Header="参数值" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Grid.Row="3" Content="添加参数" Command="{Binding RecipeVm.AddParameterCommand}" Margin="0,4,0,0" HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== 日志查看页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Log}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="12">
                        <WrapPanel>
                            <TextBlock Text="级别:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding LogVm.LevelOptions}" SelectedItem="{Binding LogVm.FilterLevel}" Width="80" Margin="0,0,12,0"/>
                            <TextBlock Text="来源:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding LogVm.FilterSource, UpdateSourceTrigger=PropertyChanged}" Width="100" Margin="0,0,12,0"/>
                            <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding LogVm.SearchKeyword, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,12,0"/>
                            <Button Content="筛选" Command="{Binding LogVm.ApplyFilterCommand}" Margin="4,0" Background="#2196F3" Foreground="White"/>
                            <Button Content="清除" Command="{Binding LogVm.ClearLogsCommand}" Margin="4,0"/>
                            <Button Content="导出" Command="{Binding LogVm.ExportLogsCommand}" Margin="4,0"/>
                            <TextBlock Text="{Binding LogVm.TotalCount, StringFormat=总计: {0}}" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="8">
                        <ListBox ItemsSource="{Binding LogVm.FilteredLogs}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas">
                                        <Run Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Foreground="#888"/>
                                        <Run Text=" ["/><Run Text="{Binding Level}" Foreground="#4CAF50"/><Run Text="] "/>
                                        <Run Text="{Binding Source}" Foreground="#2196F3"/>
                                        <Run Text=" - "/><Run Text="{Binding Message}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>

                <!-- ===================== 系统设置页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Settings}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <!-- 通讯设置 -->
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="通讯设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="TCP服务端端口" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.TcpServerPort}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="心跳间隔(ms)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.HeartbeatInterval}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="重连间隔(ms)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.ReconnectInterval}" Width="120"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <!-- SECS/GEM设置 -->
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="SECS/GEM设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="Host IP" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.SecsHostIp}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="Port" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.SecsPort}" Width="80"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="T3超时(s)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.SecsT3Timeout}" Width="80"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <!-- 运动控制设置 -->
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="运动控制设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="全局最大速度(mm/s)" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.GlobalMaxSpeed}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="全局最大加速度" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox Text="{Binding SettingsVm.GlobalMaxAccel}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <CheckBox Content="启用软限位" IsChecked="{Binding SettingsVm.EnableSoftLimit}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <CheckBox Content="启用安全互锁" IsChecked="{Binding SettingsVm.EnableInterlock}"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <!-- 系统设置 -->
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="系统设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="语言" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <ComboBox ItemsSource="{Binding SettingsVm.Languages}" SelectedItem="{Binding SettingsVm.SelectedLanguage}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="主题" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <ComboBox ItemsSource="{Binding SettingsVm.Themes}" SelectedItem="{Binding SettingsVm.SelectedTheme}" Width="120"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,24,8">
                                            <TextBlock Text="日志级别" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <ComboBox ItemsSource="{Binding SettingsVm.LogLevels}" SelectedItem="{Binding SettingsVm.SelectedLogLevel}" Width="120"/>
                                        </StackPanel>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="保存设置" Command="{Binding SettingsVm.SaveSettingsCommand}" Margin="0,0,8,0" Background="#4CAF50" Foreground="White"/>
                                        <Button Content="恢复默认" Command="{Binding SettingsVm.RestoreDefaultsCommand}" Margin="0,0,8,0"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ===================== 用户管理页面 ===================== -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=User}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 登录面板 -->
                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="24">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="用户登录" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                            <TextBlock Text="用户名" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding UserVm.Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <TextBlock Text="密码" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"/>
                            <Button Content="登录" Command="{Binding UserVm.LoginCommand}" Background="#2196F3" Foreground="White" Height="36" Margin="0,0,0,8"/>
                            <Button Content="登出" Command="{Binding UserVm.LogoutCommand}" Height="36" Margin="0,0,0,16"/>
                            <TextBlock Text="{Binding UserVm.StatusMessage}" Foreground="#FF9800" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 用户信息 -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="8" Padding="24">
                        <StackPanel>
                            <TextBlock Text="当前用户信息" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="登录状态:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserVm.LoginStatus}" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBlock Grid.Row="1" Text="用户角色:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UserVm.CurrentRole}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Text="上次登录:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UserVm.LastLoginTime}" VerticalAlignment="Center"/>
                            </Grid>

                            <Separator Margin="0,16"/>
                            <TextBlock Text="默认用户账号" FontSize="14" FontWeight="Bold" Margin="0,8,0,8"/>
                            <TextBlock Text="操作员: operator / 123456" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2"/>
                            <TextBlock Text="工程师: engineer / engineer" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2"/>
                            <TextBlock Text="管理员: admin / admin123" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{DynamicResource HeaderBrush}">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="SmartSemiCon V1.0 | .NET 9 + WPF + MVVM | 半导体设备工业控制平台"
                           Foreground="#AAA" VerticalAlignment="Center" FontSize="11"/>

                <TextBlock Grid.Column="1" Text="{Binding CurrentUserName}"
                           Foreground="#AAA" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>

                <TextBlock Grid.Column="2" Text="{Binding CurrentTime}"
                           Foreground="#AAA" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
